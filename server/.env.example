# Database Configuration
# PostgreSQL is required for checkpointer and VFS backend
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/postgres

# Model Provider Settings
# Supported: openai, anthropic, gemini
DEEPAGENT_MODEL_PROVIDER=openai
DEEPAGENT_MODEL_NAME=gpt-4o
OPENAI_API_KEY=your-openai-api-key-here

# If using Anthropic:
# DEEPAGENT_MODEL_PROVIDER=anthropic
# DEEPAGENT_MODEL_NAME=claude-3-5-sonnet-latest
# ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Observability Configuration (Opik)
OPIK_PROJECT_NAME=si-agent-scaffolding
# OPIK_API_KEY=your-opik-api-key-here # Uncomment if using Opik cloud. Leave commented for local Opik instance.
# OPIK_URL_OVERRIDE=http://localhost:5173/opik/api # Uncomment if using self-hosted Opik on a custom URL

# Server Settings
PORT=8000
HOST=0.0.0.0
